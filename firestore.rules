rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic protection against spam and multiple accounts (simulated)
    match /system_limits/{hash} {
      allow read: if false;
      allow create: if request.auth != null;
    }

    // Users profile
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Addons stats
    match /addons/{addonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Comments & Nested Replies
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'repliesCount']));
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }
    
    // Likes tracking
    match /likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null && likeId.startsWith(request.auth.uid);
    }
    
    // Favorites
    match /favorites/{favId} {
      allow read: if true;
      allow write: if request.auth != null && favId.startsWith(request.auth.uid);
    }
    
    // Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && ratingId.startsWith(request.auth.uid);
      allow update: if false;
    }
    
    // Downloads
    match /downloads/{dwId} {
      allow read: if true;
      allow write: if request.auth != null && dwId.startsWith(request.auth.uid);
    }
  }
}
