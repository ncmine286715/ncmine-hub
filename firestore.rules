rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ USUÁRIOS ============
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Próprio usuário edita tudo; qualquer logado pode incrementar 'points' (XP de terceiros — ex. ao curtir)
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'updatedAt'])
      );
      allow delete: if false;
    }

    // ============ ADDONS (estatísticas agregadas) ============
    match /addons/{addonId} {
      allow read: if true;
      // Qualquer logado pode atualizar contadores (downloads/views/etc.)
      allow write: if request.auth != null;
    }

    // ============ COMENTÁRIOS ============
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'repliesCount'])
      );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }

    // ============ LIKES / FAVORITOS / RATINGS / DOWNLOADS ============
    match /likes/{likeId} {
      allow read: if true;
      allow write: if request.auth != null && likeId.matches(request.auth.uid + '_.*');
    }
    match /favorites/{favId} {
      allow read: if true;
      allow write: if request.auth != null && favId.matches(request.auth.uid + '_.*');
    }
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && ratingId.matches(request.auth.uid + '_.*');
      allow update: if false;
    }
    match /downloads/{dwId} {
      allow read: if true;
      allow write: if request.auth != null && dwId.matches(request.auth.uid + '_.*');
    }

    // ============ ANALYTICS (anônimo OK) ============
    // Eventos brutos: qualquer um cria (mesmo deslogado), ninguém lê salvo admin.
    match /public_events/{evId} {
      allow create: if true;
      allow read: if request.auth != null &&
                  request.auth.token.email == 'rosidomingos032@gmail.com';
      allow update, delete: if false;
    }

    // Estatísticas diárias agregadas (contadores): qualquer um incrementa.
    match /daily_stats/{dayId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // ============ RATE LIMIT / SYSTEM ============
    match /system_limits/{docId} {
      allow read: if false;
      allow create: if request.auth != null;
    }
    match /rate_limits/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============ NOTIFICAÇÕES GLOBAIS (só admin via app) ============
    match /global_notifications/{notifId} {
      allow read: if true;
      allow create: if request.auth != null &&
                    request.auth.token.email == 'rosidomingos032@gmail.com';
      allow update, delete: if false;
    }
  }
}